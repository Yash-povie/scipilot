# ── Postgres
POSTGRES_USER=scipilot
POSTGRES_PASSWORD=scipilot_secret
POSTGRES_DB=scipilot
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# ── Redis
REDIS_URL=redis://redis:6379/0
# ── Neo4j
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_secret
# ── MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=scipilot
# ── JWT
JWT_SECRET=change_this_in_production_use_256_bit_key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
# ── LLM
ANTHROPIC_API_KEY=your_anthropic_key_here
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6
# ── LangSmith
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_key_here
LANGCHAIN_PROJECT=scipilot
# ── OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
OTEL_SERVICE_NAME=scipilot
# ── Rate Limiting
RATE_LIMIT_PER_MINUTE=60